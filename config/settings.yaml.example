app:
  name: "mul-agent"
  version: "0.1.0"
  debug: true

server:
  host: "0.0.0.0"
  port: 8000

database:
  url: "postgresql+asyncpg://mulagent:mulagent@localhost:5432/mulagent"
  echo: false

redis:
  url: "redis://localhost:6379/0"

qdrant:
  url: "http://localhost:6333"
  collection_name: "case_library"

# 多模型配置：在models下定义多个模型，default指定默认使用哪个
# API请求时可通过 model 参数选择，如 {"input": "...", "model": "deepseek"}
llm:
  default: "qwen"
  models:
    qwen:
      name: "Qwen 3.5 Plus"
      model: "qwen3.5-plus"
      api_key: ""                                    # 填入你的 API Key
      base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
      max_tokens: 65536
    # deepseek:
    #   name: "DeepSeek V3"
    #   model: "deepseek-chat"
    #   api_key: ""
    #   base_url: "https://api.deepseek.com/v1"
    #   max_tokens: 8192
    # openai:
    #   name: "GPT-4o"
    #   model: "gpt-4o"
    #   api_key: ""
    #   base_url: ""
    #   temperature: 0.1
    #   max_tokens: 4096
    # ollama:
    #   name: "Local Qwen"
    #   model: "qwen2.5:14b"
    #   api_key: ""
    #   base_url: "http://localhost:11434/v1"
    #   max_tokens: 4096

# Embedding 模型配置（用于语义检索和经验库）
# 支持 OpenAI 兼容的 embedding API
# 未配置时降级为 LLM 关键词提取 + 语义哈希
embedding:
  model: "text-embedding-v3"
  api_key: ""                 # 留空时尝试复用 LLM 的 API key
  base_url: ""                # 留空时尝试复用 LLM 的 base_url
  dimensions: 1024

# ReAct 推理引擎配置
react:
  max_rounds: 30             # 最大推理轮数（复杂任务建议 30+）
  timeout: 600               # 整体超时（秒）— 单工具超时自动推导为 timeout/10
  max_parallel_tools: 5      # 工具并行执行上限
  max_conversation_pairs: 4  # 保留的对话轮数
  compress:
    # Facts 压缩
    facts_compact_trigger: 15    # facts 超过此数触发压缩
    facts_keep_recent: 5         # 压缩时保留最近 N 条
    tool_result_max_tokens: 1500 # 单个工具结果截断上限 (token)
    # 上下文压缩预算
    context_compress_ratio: 0.15  # 压缩 token 预算 = context_window × ratio（范围 0.01~0.5）
    context_max_chars: 0          # 显式覆盖（>0 时优先于 ratio，向后兼容，单位：字符）
    # 四级压缩阈值（相关性分数）
    level_full: 0.7              # ≥此值 → 完整保留
    level_summary: 0.3           # ≥此值 → 摘要
    level_title: 0.1             # ≥此值 → 仅标题；低于此值 → 隐藏
    # 相关性三信号权重（总和应为 1.0）
    weight_keyword: 0.5          # 关键词重叠 (Jaccard)
    weight_recall: 0.3           # 召回意图检测
    weight_decay: 0.2            # 时间衰减
    # 话题归档
    archive_threshold: 30        # 自动归档：超过 N 轮归档冷话题
    archive_manual_threshold: 6  # 手动压缩（/compress）时的归档阈值
    decay_half_life_hours: 24.0  # 时间衰减半衰期（小时）

feishu:
  app_id: ""               # 飞书应用 App ID
  app_secret: ""           # 飞书应用 App Secret
  autostart: false         # 是否开机自启（true 时 enable systemd 服务）

project_pilot:
  max_iterations: 3            # 最大迭代轮次（Plan→Execute→Review 循环）
  max_subtask_retries: 2       # 单个子任务最多重做次数
  convergence_threshold: 2     # 连续 N 轮评分无提升则停止
  max_parallel_subtasks: 3     # 最大并行子任务数（子任务超时继承 react.timeout）

sandbox:
  enabled: true                # 启用 Docker 沙箱（不可用时自动降级为直接执行）
  image: "python:3.12-slim"    # 沙箱镜像
  memory_limit: "512m"         # 内存限制
  cpu_limit: 1.0               # CPU 核数限制
  network: true                # 是否允许网络
  workdir: "/workspace"        # 容器内工作目录

security:
  max_sandbox_timeout_seconds: 300
  max_sandbox_memory_mb: 512

observability:
  enable_prometheus: true          # 暴露 /metrics 端点
  enable_tracing: true             # 启用分布式追踪
  alert_webhook_url: ""            # 告警 webhook（可选，如飞书/钉钉 webhook）
  metrics_retention_minutes: 60    # 内存指标保留时间（分钟）

# ── 工具钩子（可选）──────────────────────────────────────────────
# 在工具执行前/后自动运行 shell 命令
# pre hook 返回非 0 → 阻止工具执行；post hook 仅记录
# {path}, {command}, {action}, {args} 等自动替换为工具实际参数
#
# hooks:
#   pre:
#     write_file: "bash scripts/hooks/guard_file.sh '{path}' write"
#     edit_file: "bash scripts/hooks/guard_file.sh '{path}' edit"
#     execute_shell: "bash scripts/hooks/guard_shell.sh '{command}'"
#     git_ops: "bash scripts/hooks/guard_git.sh '{action}' '{args}'"
#   post:
#     write_file: "echo '{\"ts\":\"'$(date -Iseconds)'\",\"event\":\"WRITE_DONE\",\"file\":\"{path}\"}' >> data/audit/file_audit.jsonl"
#     code_run: "echo '{\"ts\":\"'$(date -Iseconds)'\",\"event\":\"CODE_DONE\",\"lang\":\"{language}\"}' >> data/audit/code_audit.jsonl"
